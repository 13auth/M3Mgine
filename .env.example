# CCE ortam değişkenleri — kopyala: cp .env.example .env (docker-compose okur)
# Anahtarları buraya koy; .env'i ASLA commit etme (secrets).

# LLM hattı (BYO-key). OpenAI-uyumlu taban. Örn: OpenRouter https://openrouter.ai/api/v1
# Lokal Ollama örneği: http://127.0.0.1:11434/v1
CCE_LLM_BASE_URL=
CCE_LLM_MODEL=gpt-4o-mini
CCE_LLM_API_KEY=
CCE_EMBED_MODEL=text-embedding-3-small

# Ödeme webhook HMAC secret (boşsa webhook tüm istekleri reddeder)
CCE_WEBHOOK_SECRET=

# Limitler / metering
CCE_RATE_RPM=120
CCE_JUDGE_VOTES=1
CCE_MAX_BODY=262144
CCE_MAX_TEXT=20000
CCE_MAX_FACTS=100
